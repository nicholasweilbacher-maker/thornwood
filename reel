<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Thornwood · 15s Reel</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700&family=Cinzel:wght@400;600&family=IM+Fell+English:ital@0;1&display=swap" rel="stylesheet">
<style>
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  body{background:#000;display:flex;align-items:center;justify-content:center;min-height:100vh;font-family:'IM Fell English',serif;overflow:hidden}

/* ── REEL STAGE ── */
.reel{
position:relative;width:min(100vw,540px);
aspect-ratio:9/16;background:#040d04;overflow:hidden;
box-shadow:0 0 80px rgba(0,0,0,.9);
}

/* ── CINEMATIC BARS ── */
.bar{position:absolute;left:0;right:0;height:7%;background:#000;z-index:50}
.bar-top{top:0} .bar-bot{bottom:0}

/* ── PROGRESS BAR ── */
.progress{
position:absolute;bottom:7%;left:0;right:0;height:2px;background:rgba(255,255,255,.12);z-index:60
}
.progress-fill{height:100%;background:linear-gradient(to right,#8a6820,#f0c830,#8a6820);width:0;animation:prog 15s linear forwards}

/* ── PHOTO PANELS ── */
.panel{
position:absolute;inset:0;overflow:hidden;opacity:0;
transition:opacity .0s;
}
.panel img{width:100%;height:100%;object-fit:cover;transform:scale(1.12);animation:none}
.panel .veil{position:absolute;inset:0}
.panel.active{opacity:1}
.panel.active img{animation:kz 6s ease forwards}

/* ── GRAIN ── */
.grain{
position:absolute;inset:0;z-index:45;opacity:.03;pointer-events:none;
background-image:url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 200 200’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘n’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=’.85’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23n)’/%3E%3C/svg%3E”);
background-size:120px;
}

/* ── VIGNETTE ── */
.vignette{position:absolute;inset:0;z-index:44;pointer-events:none;background:radial-gradient(ellipse at 50% 50%,transparent 40%,rgba(0,0,0,.72) 100%)}

/* ── SCENE CONTENT ── */
.scene{position:absolute;inset:0;z-index:46;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:10% 8%;text-align:center;opacity:0;pointer-events:none}

/* ── FIREFLIES ── */
.firefly{position:absolute;width:2px;height:2px;border-radius:50%;background:#f4e040;pointer-events:none;z-index:47}

/* ──────────────────── ANIMATIONS ──────────────────── */
@keyframes prog{from{width:0}to{width:100%}}
@keyframes kz{from{transform:scale(1.12)}to{transform:scale(1.04)}}

/* Scene 1 — 0–3s: Logo reveal */
@keyframes s1-tree {0%{opacity:0;transform:scale(.7)}30%{opacity:1;transform:scale(1.04)}50%{transform:scale(.98)}100%{opacity:1;transform:scale(1)}}
@keyframes s1-logo {0%,30%{opacity:0;transform:translateY(14px)}40%{opacity:1;transform:translateY(0)}100%{opacity:1;transform:translateY(0)}}
@keyframes s1-tag  {0%,55%{opacity:0;letter-spacing:12px}70%{opacity:.7;letter-spacing:6px}100%{opacity:.7;letter-spacing:6px}}
@keyframes s1-fade {0%{opacity:0}5%{opacity:1}85%{opacity:1}100%{opacity:0}}

/* Scene 2 — 3–6s: Find your roots */
@keyframes s2-line {0%{width:0;opacity:0}20%{opacity:1}100%{width:100%;opacity:1}}
@keyframes s2-text {0%,15%{opacity:0;transform:translateY(18px)}35%{opacity:1;transform:translateY(0)}85%{opacity:1}100%{opacity:0}}
@keyframes s2-sub  {0%,40%{opacity:0}60%{opacity:.65}85%{opacity:.65}100%{opacity:0}}
@keyframes s2-fade {0%{opacity:0}8%{opacity:1}85%{opacity:1}100%{opacity:0}}

/* Scene 3 — 6–9s: Oracle / wisdom */
@keyframes s3-card {0%,5%{opacity:0;transform:rotateY(-18deg) scale(.88)}25%{opacity:1;transform:rotateY(0) scale(1)}85%{opacity:1}100%{opacity:0;transform:scale(.96)}}
@keyframes s3-text {0%,35%{opacity:0;transform:translateY(10px)}50%{opacity:1;transform:translateY(0)}85%{opacity:1}100%{opacity:0}}
@keyframes s3-fade {0%{opacity:0}8%{opacity:1}85%{opacity:1}100%{opacity:0}}

/* Scene 4 — 9–12s: Community */
@keyframes s4-a   {0%,0%{opacity:0;transform:scale(.9) translateX(-12px)}20%{opacity:1;transform:scale(1) translateX(0)}85%{opacity:1}100%{opacity:0}}
@keyframes s4-b   {0%,25%{opacity:0;transform:scale(.9) translateX(12px)}45%{opacity:1;transform:scale(1) translateX(0)}85%{opacity:1}100%{opacity:0}}
@keyframes s4-tag {0%,55%{opacity:0}70%{opacity:.75}85%{opacity:.75}100%{opacity:0}}
@keyframes s4-fade{0%{opacity:0}8%{opacity:1}85%{opacity:1}100%{opacity:0}}

/* Scene 5 — 12–15s: CTA */
@keyframes s5-ring {0%{opacity:0;transform:scale(.4)}20%{opacity:1;transform:scale(1)}70%{opacity:.6;transform:scale(1.06)}100%{opacity:.4;transform:scale(1.14)}}
@keyframes s5-logo {0%,18%{opacity:0;transform:scale(.85)}35%{opacity:1;transform:scale(1)}85%{opacity:1}100%{opacity:1}}
@keyframes s5-tag  {0%,40%{opacity:0;letter-spacing:14px}60%{opacity:.8;letter-spacing:8px}100%{opacity:.8;letter-spacing:8px}}
@keyframes s5-cta  {0%,60%{opacity:0;transform:translateY(10px)}75%{opacity:1;transform:translateY(0)}100%{opacity:1}}
@keyframes s5-fade {0%{opacity:0}8%{opacity:1}90%{opacity:1}100%{opacity:1}}

/* Firefly animations */
@keyframes ff1{0%{opacity:0;transform:translate(0,0)}20%{opacity:.9}50%{transform:translate(38px,-52px);opacity:.7}80%{opacity:.5}100%{opacity:0;transform:translate(14px,-90px)}}
@keyframes ff2{0%{opacity:0;transform:translate(0,0)}15%{opacity:.8}60%{transform:translate(-44px,-30px);opacity:.6}100%{opacity:0;transform:translate(-20px,-70px)}}
@keyframes ff3{0%{opacity:0}25%{opacity:1}50%{transform:translate(28px,22px)}100%{opacity:0;transform:translate(50px,-40px)}}
@keyframes glow{0%,100%{box-shadow:0 0 3px #f4e040,0 0 8px rgba(244,224,64,.3)}50%{box-shadow:0 0 8px #f4e040,0 0 22px rgba(244,224,64,.6)}}

/* ──── TIMED VISIBILITY ──── */
/* Panels */
#p1{animation:s1-fade 3.4s 0s   linear forwards}
#p2{animation:s2-fade 3.4s 3s   linear forwards}
#p3{animation:s3-fade 3.4s 6s   linear forwards}
#p4{animation:s4-fade 3.4s 9s   linear forwards}
#p5{animation:s5-fade 3.4s 12s  linear forwards}

/* Scene visibility */
#sc1{animation:s1-fade 3.2s 0s   linear forwards}
#sc2{animation:s2-fade 3.2s 3s   linear forwards}
#sc3{animation:s3-fade 3.2s 6s   linear forwards}
#sc4{animation:s4-fade 3.2s 9s   linear forwards}
#sc5{animation:s5-fade 3.2s 12s  linear forwards}

/* ──── CONTENT ANIMATIONS ──── */
.s1-tree{animation:s1-tree 2.5s .2s ease forwards;opacity:0}
.s1-logo{animation:s1-logo 2s .5s ease forwards;opacity:0}
.s1-tag {animation:s1-tag  1.5s 1.2s ease forwards;opacity:0}

.s2-line{height:1px;background:linear-gradient(to right,transparent,#d4a820,transparent);width:0;animation:s2-line 1s 3.3s ease forwards}
.s2-text{animation:s2-text 2.8s 3s ease forwards;opacity:0}
.s2-sub {animation:s2-sub  2s   3s ease forwards;opacity:0}

.s3-card{animation:s3-card 2.8s 6s cubic-bezier(.2,0,.2,1) forwards;opacity:0}
.s3-text{animation:s3-text 2s   6s ease forwards;opacity:0}

.s4-a  {animation:s4-a    2.5s 9s   ease forwards;opacity:0}
.s4-b  {animation:s4-b    2.5s 9s   ease forwards;opacity:0}
.s4-tag{animation:s4-tag  2s   9s   ease forwards;opacity:0}

.s5-ring{animation:s5-ring 2.5s 12s  ease forwards;opacity:0}
.s5-logo{animation:s5-logo 2s   12s  ease forwards;opacity:0}
.s5-tag {animation:s5-tag  1.8s 12.5s ease forwards;opacity:0}
.s5-cta {animation:s5-cta  1.5s 13.2s ease forwards;opacity:0}

/* Replay button */
.replay{
position:fixed;bottom:20px;left:50%;transform:translateX(-50%);
padding:10px 26px;background:rgba(212,168,32,.15);
border:1px solid rgba(212,168,32,.5);border-radius:30px;
color:#f0c830;font-family:‘Cinzel’,serif;font-size:12px;letter-spacing:3px;
cursor:pointer;z-index:200;opacity:0;
animation:fadeReplay 1s 15s forwards;
transition:background .2s;
}
.replay:hover{background:rgba(212,168,32,.28)}
@keyframes fadeReplay{from{opacity:0}to{opacity:1}}

/* Stars */
.star{position:absolute;background:#f0e8d0;border-radius:50%;z-index:43}
@keyframes twk{0%,100%{opacity:.6}50%{opacity:.04}}
</style>

</head>
